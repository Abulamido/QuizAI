<table>
<thead>
<tr>
<th>Percentage</th>
<th>Grade</th>
</tr>
</thead>
<tbody>
<tr>
<td>90–100%</td>
<td>A</td>
</tr>
<tr>
<td>80–89%</td>
<td>B</td>
</tr>
<tr>
<td>70–79%</td>
<td>C</td>
</tr>
<tr>
<td>60–69%</td>
